if [ -n "$INSIDE_EMACS" ]; then
	# 2020-08-29, jsled: https://github.com/akermu/emacs-libvterm
	vterm_printf() {
		if [ -n "$TMUX" ]; then
			# Tell tmux to pass the escape sequences through
			# (Source: http://permalink.gmane.org/gmane.comp.terminal-emulators.tmux.user/1324)
			printf "\ePtmux;\e\e]%s\007\e\\" "$1"
		elif [ "${TERM%%-*}" = "screen" ]; then
			# GNU screen (screen, screen-256color, screen-256color-bce)
			printf "\eP\e]%s\007\e\\" "$1"
		else
			printf "\e]%s\e\\" "$1"
		fi
	}

	vterm_prompt_end() {
		vterm_printf "51;A$(whoami)@$(hostname):$(pwd)"
	}

	if [[ ${INSIDE_EMACS:-no} = "vterm" ]]; then
		export PS1=${PS1}'\[$(vterm_prompt_end)\]'
	fi

	vterm_cmd() {
		local vterm_elisp
		vterm_elisp=""
		while [ $# -gt 0 ]; do
			vterm_elisp="$vterm_elisp""$(printf '"%s" ' "$(printf "%s" "$1" | sed -e 's|\\|\\\\|g' -e 's|"|\\"|g')")"
			shift
		done
		vterm_printf "51;E$vterm_elisp"
	}

	alias vi='vterm_cmd find-file'
	alias vim='vterm_cmd find-file'
	alias _e='vterm_cmd find-file'

	export VISUAL=emacsclient
	export PAGER=cat
	alias magit="emacsclient -ne '(magit-status)'"

	function man() { emacsclient -ne "(man \"$1\")"; }
fi
